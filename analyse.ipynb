import os
import pandas as pd
from IPython.display import display

# Folosește directorul curent
folder = os.path.join(os.getcwd(), "MBT")
file_list = []

for root, dirs, files in os.walk(folder):
    for file in files:
        if file.startswith("P4M"):
            full_path = os.path.join(root, file)
            file_list.append({
                'File Name': file,
                #'Full Path': full_path,
                #'Extension': os.path.splitext(file)[1].lower()
            })

df = pd.DataFrame(file_list)

# Analiză de bază
print("Folder:",folder)
print(f"Total fișiere găsite: {len(df)}")
print("\nFrecvența extensiilor:")
#print(df['Extension'].value_counts())

print("\nPrimele 10 fișiere:")
#print(df.head(10))
display(df)
